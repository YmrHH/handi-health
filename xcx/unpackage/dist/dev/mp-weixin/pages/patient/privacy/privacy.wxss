.pv { padding-top: 22rpx;
}
.pv-head { padding: 26rpx;
}
.pv-title { font-size: 36rpx; font-weight: 900; color: var(--c-text);
}
.pv-sub { margin-top: 10rpx; font-size: 26rpx; color: var(--c-subtext); line-height: 38rpx;
}
.pv-section { margin-top: 18rpx; padding: 10rpx 6rpx;
}
.pv-card { padding: 22rpx;
}
.pv-row { display: flex; justify-content: space-between; align-items: center;
}
.pv-left { flex: 1; padding-right: 18rpx;
}
.pv-name { font-size: 28rpx; font-weight: 800; color: rgba(31,42,55,0.86);
}
.pv-desc { margin-top: 6rpx; font-size: 24rpx; color: rgba(31,42,55,0.55); line-height: 34rpx;
}
.pv-status { font-size: 24rpx; color: rgba(31,42,55,0.65);
}
.pv-divider { height: 1rpx; background: rgba(91,108,255,0.10); margin: 14rpx 0;
}
.pv-actions { margin-top: 16rpx; display: flex; gap: 12rpx;
}
.pv-actions-single { display: block;
}
.pv-btn { flex: 1; padding: 16rpx 0; border-radius: 999rpx; text-align: center;
}
.pv-btn-text { font-size: 26rpx; color: rgba(31,42,55,0.78); font-weight: 800;
}
.pv-bullets { display: flex; flex-direction: column; gap: 10rpx;
}
.pv-bullet { display: flex; align-items: flex-start; gap: 10rpx;
}
.pv-dot { font-size: 28rpx; color: rgba(91,108,255,0.75); line-height: 34rpx;
}
.pv-text { flex: 1; font-size: 26rpx; color: rgba(31,42,55,0.74); line-height: 38rpx;
}
.pv-danger { padding: 18rpx 0; border-radius: 999rpx;
}
.pv-danger-text { display: block; text-align: center; font-size: 28rpx; font-weight: 900; color: #fff;
}
.pv-note { margin-top: 14rpx; padding: 14rpx 16rpx; border-radius: 18rpx; background: rgba(91,108,255,0.08); border: 1rpx solid rgba(91,108,255,0.12);
}
.pv-note-text { font-size: 24rpx; color: rgba(31,42,55,0.62); line-height: 36rpx;
}
.pv-policy { font-size: 26rpx; color: rgba(31,42,55,0.70); line-height: 40rpx;
}
