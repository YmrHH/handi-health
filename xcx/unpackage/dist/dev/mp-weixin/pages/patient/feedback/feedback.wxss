.fb { padding-top: 22rpx;
}
.fb-head { padding: 26rpx;
}
.fb-title { font-size: 36rpx; font-weight: 900; color: var(--c-text);
}
.fb-sub { margin-top: 10rpx; font-size: 26rpx; color: var(--c-subtext); line-height: 38rpx;
}
.fb-section { margin-top: 18rpx; padding: 10rpx 6rpx;
}
.fb-card { padding: 22rpx;
}
.fb-row { display: flex; align-items: center; justify-content: space-between;
}
.fb-row-top { margin-top: 14rpx;
}
.fb-row-between { align-items: baseline;
}
.fb-label { font-size: 28rpx; font-weight: 800; color: rgba(31,42,55,0.80);
}
.fb-mini { font-size: 24rpx; color: rgba(31,42,55,0.50);
}
.fb-picker {
  min-width: 260rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(91,108,255,0.14);
}
.fb-picker-text { font-size: 26rpx; color: rgba(31,42,55,0.78);
}
.fb-arrow { margin-left: 10rpx; font-size: 30rpx; color: rgba(31,42,55,0.45);
}
.fb-textarea {
  margin-top: 10rpx;
  width: 100%;
  min-height: 170rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(91,108,255,0.12);
  font-size: 26rpx;
  color: rgba(31,42,55,0.86);
}
.fb-hint { margin-top: 8rpx; font-size: 22rpx; color: rgba(31,42,55,0.45); text-align: right;
}
.fb-input {
  margin-top: 10rpx;
  width: 100%;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(91,108,255,0.12);
  font-size: 26rpx;
  color: rgba(31,42,55,0.86);
}
.fb-images { margin-top: 12rpx; display: flex; flex-wrap: wrap; gap: 12rpx;
}
.fb-imgbox { width: 150rpx; height: 150rpx; border-radius: 18rpx; overflow: hidden; position: relative; border: 1rpx solid rgba(91,108,255,0.12); background: rgba(255,255,255,0.9);
}
.fb-img { width: 150rpx; height: 150rpx;
}
.fb-del { position: absolute; top: 6rpx; right: 6rpx; width: 34rpx; height: 34rpx; border-radius: 999rpx; background: rgba(31,42,55,0.70); display: flex; align-items: center; justify-content: center;
}
.fb-del-text { color: #fff; font-size: 22rpx; font-weight: 900;
}
.fb-add { width: 150rpx; height: 150rpx; border-radius: 18rpx; border: 1rpx dashed rgba(91,108,255,0.30); background: rgba(255,255,255,0.75); display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.fb-add-text { font-size: 44rpx; font-weight: 900; color: rgba(91,108,255,0.75); line-height: 44rpx;
}
.fb-add-sub { margin-top: 6rpx; font-size: 22rpx; color: rgba(31,42,55,0.55);
}
.fb-submit { margin-top: 18rpx; padding: 18rpx 0; border-radius: 999rpx;
}
.fb-submit-text { display: block; text-align: center; font-size: 30rpx; font-weight: 900; color: #fff;
}
.fb-note { margin-top: 14rpx; padding: 14rpx 16rpx; border-radius: 18rpx; background: rgba(91,108,255,0.08); border: 1rpx solid rgba(91,108,255,0.12);
}
.fb-note-text { font-size: 24rpx; color: rgba(31,42,55,0.60); line-height: 36rpx;
}
.fb-empty { padding: 26rpx 0; text-align: center;
}
.fb-empty-text { font-size: 26rpx; color: rgba(31,42,55,0.50);
}
.fb-item { padding: 16rpx; border-radius: 20rpx; background: rgba(255,255,255,0.90); border: 1rpx solid rgba(91,108,255,0.10); margin-bottom: 12rpx;
}
.fb-item-type { font-size: 26rpx; font-weight: 900; color: rgba(31,42,55,0.82);
}
.fb-item-time { font-size: 22rpx; color: rgba(31,42,55,0.45);
}
.fb-item-content { margin-top: 8rpx; font-size: 26rpx; color: rgba(31,42,55,0.72); line-height: 38rpx;
}
