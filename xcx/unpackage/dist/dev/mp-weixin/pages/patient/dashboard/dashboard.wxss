/* =========================================================
   随访关联子页面（原“数据”页，已从 TabBar 移除）
   ========================================================= */
.fa { padding-top: 28rpx;
}
.fa-head { padding: 28rpx;
}
.fa-title { font-size: 34rpx; font-weight: 900; color: var(--c-text);
}
.fa-sub { margin-top: 10rpx; font-size: 24rpx; line-height: 34rpx; color: rgba(31,42,55,0.58);
}
.fa-chip{
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(255,255,255,0.92);
  color: rgba(31,42,55,0.62);
}
.fa-sum{ margin-top: 18rpx;
}
.fa-sum-item{
  width: 31%;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.65);
  border: 1rpx solid rgba(255,255,255,0.9);
}
.fa-sum-k{ font-size: 22rpx; color: rgba(31,42,55,0.50); font-weight: 700;
}
.fa-sum-v{ margin-top: 10rpx; font-size: 28rpx; font-weight: 900; color: var(--c-text);
}
.fa-section{ margin-top: 22rpx; padding: 10rpx 6rpx;
}
.fa-link-text{ font-size: 26rpx; color: var(--c-text); opacity: 0.75;
}
.fa-arrow{ margin-left: 10rpx; font-size: 34rpx; color: var(--c-text); opacity: 0.55;
}
.fa-trends{
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.fa-trend{
  margin-top: 18rpx;
  width: 48%;
  padding: 22rpx;
  position: relative;
  overflow: hidden;
}
.fa-trend:nth-child(-n+2){ margin-top: 0;
}
.fa-trend-title{ font-size: 30rpx; font-weight: 900; color: var(--c-text);
}
.fa-trend-chip{
  font-size: 22rpx;
  font-weight: 800;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(91,108,255,0.14);
  background: rgba(255,255,255,0.68);
  color: rgba(91,108,255,0.92);
}
.fa-trend-chip.high{ color: #B42318; border-color: rgba(255,99,132,0.18); background: rgba(255,99,132,0.10);
}
.fa-trend-chip.mid{ color: #92400E; border-color: rgba(245,158,11,0.18); background: rgba(245,158,11,0.10);
}
.fa-trend-chip.ok{ color: rgba(91,108,255,0.92);
}
.fa-trend-val{ margin-top: 10rpx;
}
.fa-trend-num{ font-size: 44rpx; font-weight: 900; color: var(--c-text);
}
.fa-trend-unit{ font-size: 24rpx; color: rgba(31,42,55,0.55); font-weight: 600;
}
.fa-trend-hint{ margin-top: 8rpx; font-size: 22rpx; color: rgba(31,42,55,0.55);
}
.fa-spark{
  margin-top: 14rpx;
  height: 70rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx dashed rgba(91, 108, 255, 0.14);
}
.fa-tips{ padding: 22rpx;
}
.fa-tip{ display: flex; flex-direction: row; align-items: flex-start; margin-top: 12rpx;
}
.fa-tip:first-child{ margin-top: 0;
}
.fa-tip-dot{
  width: 10rpx;
  height: 10rpx;
  margin-top: 12rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: rgba(91,108,255,0.55);
}
.fa-tip-text{ flex: 1; font-size: 26rpx; line-height: 40rpx; color: rgba(31,42,55,0.72);
}
.fa-tip-btn{ margin-top: 16rpx; padding: 14rpx 0;
}
.fa-list{ padding: 10rpx 22rpx;
}
.fa-row{ padding: 18rpx 0;
}
.fa-row + .fa-row{ border-top: 1rpx solid rgba(31,42,55,0.06);
}
.fa-row-title{ font-size: 28rpx; font-weight: 900; color: var(--c-text);
}
.fa-row-time{ font-size: 22rpx; color: rgba(31,42,55,0.50); font-weight: 700;
}
.fa-row-sub{ margin-top: 10rpx; font-size: 24rpx; line-height: 34rpx; color: rgba(31,42,55,0.62);
}
.fa-footnote{ margin-top: 20rpx; padding: 12rpx 6rpx 24rpx;
}
.fa-footnote-text{ font-size: 24rpx; color: rgba(31, 42, 55, 0.45); line-height: 34rpx;
}
