/* 健康档案页（玻璃卡片风格） */
.hf { padding-top: 18rpx;
}
.hf-top { padding: 8rpx 6rpx 18rpx;
}
.hf-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  border: 6rpx solid rgba(91, 108, 255, 0.20);
  margin-right: 14rpx;
}
.hf-name-pill {
  background: rgba(91, 108, 255, 0.12);
  border: 1rpx solid rgba(91, 108, 255, 0.18);
  border-radius: 999rpx;
  padding: 14rpx 22rpx;
}
.hf-name { font-size: 30rpx; font-weight: 700; color: #4B5563;
}
.hf-sync-pill{
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 999rpx;
  padding: 12rpx 18rpx;
  display:flex;
  align-items:center;
}
.hf-sync-dot{
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(16, 185, 129, 0.9);
  margin-right: 10rpx;
}
.hf-sync-text{ font-size: 24rpx; color: rgba(31,42,55,0.55);
}
.hf-actions{ display:flex; align-items:center;
}
.hf-icon-btn{
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: var(--shadow-soft);
  display:flex;
  align-items:center;
  justify-content:center;
}
.hf-icon{ font-size: 34rpx; color: var(--c-primary); font-weight: 700;
}
.hf-add{
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: var(--shadow-soft);
  display:flex;
  align-items:center;
  justify-content:center;
}
.hf-add-plus{ font-size: 44rpx; line-height: 44rpx; color: var(--c-primary); font-weight: 700; transform: translateY(-1rpx);
}

/* 概览 */
.hf-overview{ padding: 28rpx;
}
.hf-overview-title{ font-size: 34rpx; font-weight: 800; color: var(--c-text);
}
.hf-overview-sub{ margin-top: 10rpx; font-size: 26rpx; color: var(--c-subtext);
}
.hf-risk{ display:flex; flex-direction:column; align-items:flex-end;
}
.hf-risk-chip{
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.risk-high{ background: rgba(255, 99, 132, 0.16); color: #B42318;
}
.risk-mid{ background: rgba(245, 158, 11, 0.16); color: #92400E;
}
.risk-low{ background: rgba(16, 185, 129, 0.16); color: #065F46;
}
.hf-risk-score{ margin-top: 10rpx; font-size: 44rpx; font-weight: 900; color: var(--c-primary);
}
.hf-risk-label{ margin-top: 2rpx; font-size: 22rpx; color: rgba(31,42,55,0.55);
}
.hf-quick{ margin-top: 18rpx;
}
.hf-quick-item{
  width: 30%;
  padding: 18rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.65);
  border: 1rpx solid rgba(91,108,255,0.10);
}
.hf-quick-title{ font-size: 28rpx; font-weight: 800; color: var(--c-text);
}
.hf-quick-desc{ margin-top: 6rpx; font-size: 22rpx; color: rgba(31,42,55,0.55);
}

/* 标题行 */
.hf-section{ margin-top: 22rpx; padding: 10rpx 6rpx;
}
.hf-link-text{ font-size: 26rpx; color: var(--c-text); opacity: 0.75;
}
.hf-arrow{ margin-left: 10rpx; font-size: 34rpx; color: var(--c-text); opacity: 0.55;
}

/* 指标卡片 */
.hf-metrics{
  margin-top: 6rpx;
  display:flex;
  flex-wrap:wrap;
  justify-content: space-between;
}
.hf-metric{
  margin-top: 18rpx;
  width: 48%;
  padding: 22rpx;
  position: relative;
  overflow: hidden;
}
.hf-metric:nth-child(-n+2){ margin-top: 0;
}
.hf-metric-title{ font-size: 30rpx; font-weight: 800; color: var(--c-text);
}
.hf-metric-trend{
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}
.hf-metric-trend.up{ background: rgba(255, 99, 132, 0.14); color: #B42318;
}
.hf-metric-trend.down{ background: rgba(16, 185, 129, 0.14); color: #065F46;
}
.hf-metric-trend.mid{ background: rgba(245, 158, 11, 0.14); color: #92400E;
}
.hf-metric-trend.ok{ background: rgba(91, 108, 255, 0.12); color: var(--c-primary);
}
.hf-metric-val{ margin-top: 10rpx;
}
.hf-metric-num{ font-size: 44rpx; font-weight: 900; color: var(--c-primary);
}
.hf-metric-unit{ font-size: 24rpx; color: rgba(31,42,55,0.55);
}
.hf-metric-hint{ margin-top: 6rpx; font-size: 22rpx; color: rgba(31,42,55,0.45);
}
.hf-mini{
  margin-top: 14rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.55);
  border: 1rpx dashed rgba(91,108,255,0.14);
}
.mini-bp{ background-image: linear-gradient(180deg, rgba(91,108,255,0.10), rgba(91,108,255,0.0));
}
.mini-hr{ background-image: radial-gradient(circle at 30% 50%, rgba(91,108,255,0.30), transparent 60%);
}
.mini-glucose{ background-image: radial-gradient(circle at 60% 50%, rgba(138,123,255,0.25), transparent 60%);
}
.mini-weight{ background-image: linear-gradient(90deg, rgba(16,185,129,0.10), rgba(16,185,129,0.0));
}
.mini-spo2{ background-image: linear-gradient(90deg, rgba(14,165,233,0.14), rgba(255,255,255,0.0));
}
.mini-sleep{ background-image: radial-gradient(circle at 50% 50%, rgba(138,123,255,0.18), transparent 65%);
}

/* 随访关联 */
.hf-follow{ padding: 26rpx;
}
.hf-follow-title{ font-size: 30rpx; font-weight: 800; color: var(--c-text);
}
.hf-follow-sub{ margin-top: 8rpx; font-size: 24rpx; color: rgba(31,42,55,0.55);
}
.hf-follow-badge{
  background: rgba(91, 108, 255, 0.12);
  border: 1rpx solid rgba(91, 108, 255, 0.18);
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  display:flex;
  align-items:baseline;
}
.hf-follow-badge-num{ font-size: 34rpx; font-weight: 900; color: var(--c-primary);
}
.hf-follow-badge-sep{ font-size: 24rpx; color: rgba(31,42,55,0.45); margin: 0 6rpx;
}
.hf-follow-badge-total{ font-size: 24rpx; color: rgba(31,42,55,0.45); font-weight: 700;
}
.hf-follow-grid{
  margin-top: 18rpx;
  display:flex;
  flex-wrap:wrap;
  justify-content: space-between;
}
.hf-follow-item{
  width: 48%;
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.65);
  border: 1rpx solid rgba(91,108,255,0.10);
  margin-top: 12rpx;
}
.hf-follow-item:nth-child(-n+2){ margin-top: 0;
}
.hf-follow-k{ font-size: 22rpx; color: rgba(31,42,55,0.55);
}
.hf-follow-v{ margin-top: 8rpx; font-size: 26rpx; font-weight: 800; color: var(--c-text);
}

/* 病例信息 */
.hf-med{ padding: 26rpx;
}
.hf-med-title{ font-size: 30rpx; font-weight: 900; color: var(--c-text);
}
.hf-med-sub{ margin-top: 6rpx; font-size: 24rpx; color: rgba(31,42,55,0.55);
}
.hf-med-time{ text-align: right;
}
.hf-med-time-k{ font-size: 22rpx; color: rgba(31,42,55,0.45);
}
.hf-med-time-v{ margin-top: 6rpx; font-size: 24rpx; color: rgba(31,42,55,0.75); font-weight: 700;
}
.hf-med-block{ margin-top: 18rpx;
}
.hf-med-k{ font-size: 24rpx; font-weight: 800; color: rgba(31,42,55,0.75);
}
.hf-med-v{ margin-top: 8rpx; font-size: 26rpx; line-height: 40rpx; color: rgba(31,42,55,0.62);
}
.hf-med-chips{ margin-top: 14rpx; display:flex; flex-wrap:wrap;
}
.hf-chip{
  margin-right: 12rpx;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(91,108,255,0.10);
  border: 1rpx solid rgba(91,108,255,0.14);
  font-size: 22rpx;
  color: rgba(31,42,55,0.70);
  font-weight: 700;
}
.hf-med-more{ margin-top: 6rpx;
}
.hf-med-split{ height: 1rpx; background: rgba(31,42,55,0.06); margin-top: 18rpx;
}
.hf-footnote{ margin-top: 22rpx; padding: 14rpx 6rpx;
}
.hf-footnote-text{ font-size: 24rpx; color: rgba(31,42,55,0.42); line-height: 34rpx;
}
