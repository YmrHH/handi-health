<view class="app-page fd"><view class="app-card app-card--glass fd-head"><view class="flex-row items-start justify-between"><view class="flex-col"><text class="fd-title">随访详情</text><text class="fd-sub">查看历史随访记录，并可主动申请随访</text></view><view class="{{['fd-chip', b]}}"><text class="fd-chip-text">{{a}}</text></view></view><view class="fd-kv"><view class="fd-kv-row"><text class="fd-k">上次随访时间</text><text class="fd-v">{{c}}</text></view><view class="fd-kv-row"><text class="fd-k">随访结论</text><text class="fd-v">{{d}}</text></view><view class="fd-kv-row"><text class="fd-k">记录摘要</text><text class="fd-v">{{e}}</text></view></view></view><view class="fd-section flex-row items-center justify-between"><text class="app-section-title">随访记录</text><view class="fd-link flex-row items-center" bindtap="{{f}}"><text class="fd-link-text">刷新</text><text class="fd-arrow">›</text></view></view><view class="app-card fd-list"><view wx:if="{{g}}" class="fd-empty"><text class="fd-empty-text">暂无随访记录</text></view><view wx:for="{{h}}" wx:for-item="r" wx:key="g" class="fd-item" bindtap="{{r.h}}"><view class="flex-row items-center justify-between"><text class="fd-item-time">{{r.a}}</text><view class="{{['fd-badge', r.c]}}"><text class="fd-badge-text">{{r.b}}</text></view></view><text class="fd-item-result">{{r.d}}</text><text class="fd-item-summary">{{r.e}}</text><view class="fd-item-foot flex-row items-center justify-between"><text class="fd-item-doctor">随访人员：{{r.f}}</text><text class="fd-item-more">查看详情</text></view></view></view><view class="fd-section flex-row items-center justify-between"><text class="app-section-title">主动申请随访</text><view wx:if="{{i}}" class="fd-lastapply"><text class="fd-lastapply-text">最近申请：{{j}}（{{k}}）</text></view></view><view class="app-card app-card--glass fd-apply"><view class="fd-form-row"><text class="fd-label">紧急程度</text><picker range="{{m}}" value="{{n}}" bindchange="{{o}}"><view class="fd-picker"><text class="fd-picker-text">{{l}}</text><text class="fd-arrow">›</text></view></picker></view><view class="fd-form-row"><text class="fd-label">希望随访日期</text><picker mode="date" value="{{q}}" bindchange="{{r}}"><view class="fd-picker"><text class="fd-picker-text">{{p}}</text><text class="fd-arrow">›</text></view></picker></view><view class="fd-form-row"><text class="fd-label">希望联系时间</text><picker mode="time" value="{{t}}" bindchange="{{v}}"><view class="fd-picker"><text class="fd-picker-text">{{s}}</text><text class="fd-arrow">›</text></view></picker></view><view class="fd-form-block"><text class="fd-label">我的当前情况（必填）</text><block wx:if="{{r0}}"><textarea class="fd-textarea" placeholder="例如：近两天头晕、胸闷，血压偏高，睡眠变差…" maxlength="300" value="{{w}}" bindinput="{{x}}"></textarea></block><text class="fd-hint">{{y}}/300</text></view><view class="fd-form-block"><text class="fd-label">我希望随访解决的问题（必填）</text><block wx:if="{{r0}}"><textarea class="fd-textarea" placeholder="例如：想咨询用药调整、指标异常原因、康养任务如何安排…" maxlength="300" value="{{z}}" bindinput="{{A}}"></textarea></block><text class="fd-hint">{{B}}/300</text></view><view class="fd-submit" bindtap="{{C}}"><text class="fd-submit-text">提交申请</text></view><view class="fd-privacy"><text class="fd-privacy-text">提交后将进入待处理状态，医生端审核后安排随访。</text></view></view></view>