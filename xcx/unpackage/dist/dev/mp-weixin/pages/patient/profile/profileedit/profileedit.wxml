<view class="app-page pe"><view class="pe-head"><text class="pe-title">编辑个人资料</text><text class="pe-sub">用于出院后监测、预警与随访服务</text></view><view class="app-card pe-avatar-card" bindtap="{{c}}"><view class="flex-row items-center justify-between"><view class="flex-row items-center"><image class="pe-avatar" src="{{a}}" mode="aspectFill"></image><view class="flex-col"><text class="pe-name">{{b}}</text><text class="pe-tip">点击更换头像</text></view></view><text class="pe-arrow">›</text></view></view><view class="app-card pe-card"><text class="pe-section">基本信息</text><view class="pe-field flex-row items-center justify-between"><text class="pe-label">姓名</text><input class="pe-input" placeholder="请输入姓名" placeholder-class="pe-ph" value="{{d}}" bindinput="{{e}}"/></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">性别</text><picker range="{{g}}" value="{{h}}" bindchange="{{i}}"><view class="pe-picker flex-row items-center"><text class="pe-picker-text">{{f}}</text><text class="pe-arrow">›</text></view></picker></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">出生日期</text><picker mode="date" value="{{k}}" bindchange="{{l}}"><view class="pe-picker flex-row items-center"><text class="pe-picker-text">{{j}}</text><text class="pe-arrow">›</text></view></picker></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">手机号</text><input class="pe-input" type="number" maxlength="11" placeholder="用于接收提醒" placeholder-class="pe-ph" value="{{m}}" bindinput="{{n}}"/></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">身高</text><view class="flex-row items-center"><input class="pe-input pe-input-num" type="number" maxlength="3" placeholder="cm" placeholder-class="pe-ph" value="{{o}}" bindinput="{{p}}"/><text class="pe-unit">cm</text></view></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">体重</text><view class="flex-row items-center"><input class="pe-input pe-input-num" type="digit" maxlength="6" placeholder="kg" placeholder-class="pe-ph" value="{{q}}" bindinput="{{r}}"/><text class="pe-unit">kg</text></view></view></view><view class="app-card app-card--glass pe-card"><text class="pe-section">安全设置</text><view class="pe-field flex-row items-center justify-between"><text class="pe-label">旧密码</text><input type="text" password="{{true}}" placeholder="请输入旧密码" placeholder-class="pe-ph" value="{{s}}" bindinput="{{t}}"/></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">新密码</text><input type="text" password="{{true}}" placeholder="请输入新密码（不少于6位）" placeholder-class="pe-ph" value="{{v}}" bindinput="{{w}}"/></view><view class="pe-line"></view><view class="pe-field flex-row items-center justify-between"><text class="pe-label">确认新密码</text><input type="text" password="{{true}}" placeholder="再次输入新密码" placeholder-class="pe-ph" value="{{x}}" bindinput="{{y}}"/></view><view class="pe-pwd-actions"><view class="btn-secondary pe-pwd-btn" bindtap="{{z}}">修改密码</view></view><text class="pe-pwd-tip">修改成功后，请使用新密码重新登录。</text></view><view class="pe-spacer"></view><view class="pe-footer"><view class="btn-primary pe-save" hover-class="btn-hover" bindtap="{{A}}"><text class="pe-save-text">保存</text></view></view></view>