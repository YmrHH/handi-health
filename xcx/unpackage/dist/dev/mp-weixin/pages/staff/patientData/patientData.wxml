<view class="page pd-page"><view class="card"><view class="pd-header"><view><view class="pd-name">{{a}} <text wx:if="{{b}}">（{{c}}岁{{d}}）</text></view><view class="pd-sub">病种：{{e}} · 风险：{{f}}</view></view><view class="{{h}}">{{g}}</view></view></view><view class="card"><view class="section-title">今日健康指标</view><view class="grid"><view class="cell"><view class="label">收缩压</view><view class="value">{{i}} <text class="unit">mmHg</text></view></view><view class="cell"><view class="label">舒张压</view><view class="value">{{j}} <text class="unit">mmHg</text></view></view><view class="cell"><view class="label">心率</view><view class="value">{{k}} <text class="unit">次/分</text></view></view><view class="cell"><view class="label">体重</view><view class="value">{{l}} <text class="unit">kg</text></view></view><view class="cell"><view class="label">体温</view><view class="value">{{m}} <text class="unit">℃</text></view></view><view class="cell"><view class="label">步数</view><view class="value">{{n}} <text class="unit">步</text></view></view></view><view class="tip">* 数据来自患者端“填写健康指标”。</view></view><view class="card"><view class="section-title row-between"><text>健康指标查看</text><view class="seg"><view class="{{['seg-item', o]}}" bindtap="{{p}}">7天</view><view class="{{['seg-item', q]}}" bindtap="{{r}}">30天</view><view class="{{['seg-item', s]}}" bindtap="{{t}}">90天</view></view></view><view wx:if="{{v}}" class="empty">暂无历史健康指标</view><view wx:else class="history-list"><view wx:for="{{w}}" wx:for-item="h" wx:key="g" class="history-item"><view class="history-time">{{h.a}}</view><view class="history-metrics"><text class="hm">血压 {{h.b}}/{{h.c}}</text><text class="hm">心率 {{h.d}}</text><text class="hm">体重 {{h.e}}</text><text class="hm">体温 {{h.f}}</text></view></view></view><view class="tip">* 历史数据来自患者端健康指标上报。</view></view><view class="card"><view class="section-title">随访小结</view><view wx:if="{{x}}" class="empty">暂无随访记录</view><view wx:else><view class="kv"><text class="k">随访时间</text><text class="v">{{y}}</text></view><view class="kv"><text class="k">任务类型</text><text class="v">{{z}}</text></view><view class="kv"><text class="k">症状变化</text><text class="v">{{A}}</text></view><view class="kv"><text class="k">随访小结</text><text class="v">{{B}}</text></view><view class="kv"><text class="k">医护建议</text><text class="v">{{C}}</text></view><view class="kv"><text class="k">下次随访</text><text class="v">{{D}}</text></view></view><view class="tip">* 数据来自医护端提交的随访记录。</view></view><view class="card"><view class="section-title">用药与不良反应</view><view wx:if="{{E}}" class="empty">暂无随访记录</view><view wx:else><view class="kv"><text class="k">服用药品</text><text class="v">{{F}}</text></view><view class="kv"><text class="k">用药依从性</text><text class="v">{{G}}</text></view><view class="kv"><text class="k">不良反应</text><text class="v">{{H}}</text></view></view><view class="tip">* 若暂未录入用药/不良反应，请在随访表单中补充后再查看。</view></view><view class="card"><view class="section-title">最近康复任务</view><view wx:if="{{I}}" class="empty">暂无任务</view><view wx:else class="task-list"><view wx:for="{{J}}" wx:for-item="t" wx:key="d" class="task-item"><view class="task-title">{{t.a}}</view><view class="task-sub">状态：{{t.b}} · 日期：{{t.c}}</view></view></view></view><view class="card"><view class="section-title">给患者发送建议</view><block wx:if="{{r0}}"><textarea class="advice-textarea" placeholder="输入建议内容，发送后患者端将在消息中心收到（建议尽量具体，例如饮食/运动/复诊时间等）" value="{{K}}" bindinput="{{L}}"></textarea></block><button class="btn" bindtap="{{M}}">发送建议</button><view class="tip">* 该功能依赖后端接口：POST /api/staff/patients/{id}/advice</view></view></view>