/* pages/staff/alerts/alerts.wxss */
page{
  background: linear-gradient(180deg, #EDEEFF 0%, #F6F7FF 40%, #FFFFFF 100%);
}
.alerts-page {
    padding: 24rpx;
}
.card {
    background-color: #ffffff;
    border-radius: 18rpx;
    padding: 18rpx 20rpx;
    margin-bottom: 16rpx;
    box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}
.header-title {
    font-size: 32rpx;
    font-weight: 600;
}
.header-sub {
    margin-top: 6rpx;
    font-size: 24rpx;
    color: #6b7280;
}
.filter-row {
    margin-top: 14rpx;
    display: flex;
    flex-wrap: wrap;
}
.filter-chip {
    padding: 6rpx 14rpx;
    border-radius: 999rpx;
    font-size: 24rpx;
    margin-right: 10rpx;
    margin-bottom: 8rpx;
    background-color: #eff1f5;
    color: #4b5563;
}
.filter-chip.active {
    background-color: #2972f6;
    color: #ffffff;
}
.alert-card {
    font-size: 26rpx;
}
.alert-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.alert-name {
    font-size: 28rpx;
    font-weight: 600;
}
.alert-main-disease {
    margin-top: 4rpx;
    font-size: 24rpx;
    color: #6b7280;
}
.risk-tag {
    padding: 4rpx 12rpx;
    border-radius: 999rpx;
    font-size: 22rpx;
}
.risk-tag.high {
    background-color: #fee2e2;
    color: #b91c1c;
}
.risk-tag.mid {
    background-color: #fef3c7;
    color: #b45309;
}
.risk-tag.low {
    background-color: #dcfce7;
    color: #166534;
}
.alert-middle {
    margin-top: 8rpx;
}
.alert-reason {
    font-size: 24rpx;
    color: #374151;
}
.reason-chip {
    margin-left: 6rpx;
    padding: 4rpx 10rpx;
    border-radius: 999rpx;
    background-color: #e5edff;
    color: #1d4ed8;
    font-size: 22rpx;
}
.alert-latest {
    margin-top: 4rpx;
    font-size: 24rpx;
    color: #6b7280;
}
.alert-bottom {
    margin-top: 8rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.alert-plan {
    font-size: 24rpx;
    color: #4b5563;
}
.alert-status {
    padding: 4rpx 12rpx;
    border-radius: 999rpx;
    font-size: 22rpx;
}
.alert-status.todo {
    background-color: #fef3c7;
    color: #b45309;
}
.alert-status.done {
    background-color: #dcfce7;
    color: #166534;
}
.empty {
    margin-top: 20rpx;
    font-size: 24rpx;
    color: #6b7280;
    text-align: center;
}
