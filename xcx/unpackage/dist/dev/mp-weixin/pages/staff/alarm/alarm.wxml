<view class="page alerts-page"><view class="card header-card"><view class="header-title">今日告警任务</view><view class="header-sub">共 {{a}} 条，待处理 {{b}} 条</view><view class="filter-row"><view class="{{c}}" data-filter="all" bindtap="{{d}}">全部</view><view class="{{e}}" data-filter="bp" bindtap="{{f}}">血压异常</view><view class="{{g}}" data-filter="weight" bindtap="{{h}}">体温异常</view><view class="{{i}}" data-filter="symptom" bindtap="{{j}}">症状加重</view></view></view><view wx:for="{{k}}" wx:for-item="item" wx:key="p" class="card alert-card" bindtap="{{item.n}}" data-id="{{item.o}}"><view class="alert-top"><view><view class="alert-name">{{item.a}}（{{item.b}}岁{{item.c}}）</view><view class="alert-main-disease">{{item.d}}</view></view><view class="{{item.f}}">{{item.e}}</view></view><view class="alert-middle"><view class="alert-reason"> 告警原因： <text wx:for="{{item.g}}" wx:for-item="item" wx:key="b" class="reason-chip">{{item.a}}</text></view><view class="alert-latest">最近血压 {{item.h}} · 体温 {{item.i}}℃</view></view><view class="alert-bottom"><view class="alert-plan">当前计划：{{item.j}} ｜ 下次随访：{{item.k}}</view><view class="{{item.m}}">{{item.l}}</view></view></view><view wx:if="{{l}}" class="empty">当前筛选条件下暂无告警任务。</view></view>