<view class="chat-page"><view class="staff-chat-head"><view class="staff-chat-title">{{a}}</view><view class="staff-chat-sub">对话将同步到患者端「在线咨询-医生咨询」</view></view><scroll-view class="chat-body" scroll-y="{{true}}" scroll-with-animation="{{true}}" scroll-into-view="{{d}}"><block wx:for="{{b}}" wx:for-item="item" wx:key="l"><view class="{{item.j}}" id="{{item.k}}"><image wx:if="{{item.a}}" class="avatar" src="{{item.b}}" mode="aspectFill"></image><image wx:else class="avatar" src="{{item.c}}" mode="aspectFill"></image><view class="bubble"><view wx:if="{{item.d}}" class="voice-message" bindtap="{{item.g}}"><view class="voice-icon"><view class="{{item.e}}"><view class="wave-bar"></view><view class="wave-bar"></view><view class="wave-bar"></view></view></view><text class="voice-duration">{{item.f}}″</text></view><view wx:else class="bubble-text">{{item.h}}</view><view class="bubble-time">{{item.i}}</view></view></view></block><view wx:if="{{c}}" class="empty-tip"><view class="empty-title">暂无对话</view><view class="empty-sub">患者在「在线咨询-医生咨询」发送的消息会在这里显示。</view></view></scroll-view><view class="chat-input-bar"><view class="input-container"><input class="chat-input" placeholder="输入回复内容…" confirm-type="send" value="{{e}}" bindinput="{{f}}" bindconfirm="{{g}}"/><view class="{{i}}" bindtouchstart="{{j}}" bindtouchend="{{k}}" bindtouchcancel="{{l}}"><text class="voice-icon-text">{{h}}</text></view></view><button class="send-btn" type="primary" size="mini" bindtap="{{m}}">发送</button></view><view wx:if="{{n}}" class="recording-mask"><view class="recording-indicator"><view class="recording-waves"><view wx:for="{{o}}" wx:for-item="i" wx:key="a" class="wave-circle"></view></view><view class="recording-time">{{p}}s</view><view class="recording-tip">上滑取消发送</view></view></view></view>