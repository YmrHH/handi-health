
.staff-tabbar{
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}
.staff-tabbar-inner{
  height: 112rpx;
  background: rgba(255,255,255,0.92);
  border-top: 1rpx solid rgba(91,108,255,0.12);
  box-shadow: 0 -12rpx 30rpx rgba(31,42,55,0.06);
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
}
.tab-item{
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: rgba(31,42,55,0.55);
}
.tab-item.active{
  color: rgba(91,108,255,0.95);
}
.tab-ico{
  font-size: 34rpx;
  line-height: 34rpx;
}
.tab-text{
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 750;
}
.safe-area{
  height: env(safe-area-inset-bottom);
  background: rgba(255,255,255,0.92);
}
