<view class="app-page hf"><view class="hf-top flex-row items-center justify-between"><view class="hf-user flex-row items-center"><image class="hf-avatar" src="{{a}}" mode="aspectFill"></image><view class="hf-name-pill"><text class="hf-name">{{b}}</text></view><view class="hf-sync-pill ml-12"><text class="hf-sync-dot"></text><text class="hf-sync-text">{{c}}</text></view></view><view class="hf-actions flex-row items-center"><view class="hf-icon-btn" bindtap="{{d}}"><text class="hf-icon">⟳</text></view></view></view><view class="hf-overview app-card app-card--glass"><view class="hf-overview-row flex-row items-start justify-between"><view class="flex-col"><text class="hf-overview-title">健康档案</text><text class="hf-overview-sub">档案由医生端自动导入并持续更新</text></view><view class="hf-risk"><text class="{{f}}">{{e}}</text><text class="hf-risk-score">{{g}}</text><text class="hf-risk-label">健康分</text></view></view><view class="hf-quick flex-row justify-between"><view class="hf-quick-item" bindtap="{{h}}"><text class="hf-quick-title">每日统计</text><text class="hf-quick-desc">趋势与异常</text></view><view class="hf-quick-item" bindtap="{{i}}"><text class="hf-quick-title">随访任务</text><text class="hf-quick-desc">打卡与依从</text></view><view class="hf-quick-item" bindtap="{{j}}"><text class="hf-quick-title">联系医生</text><text class="hf-quick-desc">在线咨询</text></view></view></view><view class="hf-section flex-row items-center justify-between"><text class="app-section-title">身体数据</text><view class="hf-link flex-row items-center" bindtap="{{k}}"><text class="hf-link-text">查看趋势</text><text class="hf-arrow">›</text></view></view><view class="hf-metrics"><view wx:for="{{l}}" wx:for-item="m" wx:key="h" class="hf-metric app-card" bindtap="{{m.i}}"><view class="hf-metric-head flex-row items-center justify-between"><text class="hf-metric-title">{{m.a}}</text><text class="{{m.c}}">{{m.b}}</text></view><view class="hf-metric-val flex-row items-baseline"><text class="hf-metric-num">{{m.d}}</text><text class="hf-metric-unit ml-8">{{m.e}}</text></view><text class="hf-metric-hint">{{m.f}}</text><view class="{{['hf-mini', m.g]}}"></view></view></view><view class="hf-section flex-row items-center justify-between"><text class="app-section-title">随访关联</text><view class="hf-link flex-row items-center" bindtap="{{m}}"><text class="hf-link-text">查看记录</text><text class="hf-arrow">›</text></view></view><view class="hf-follow app-card app-card--glass" bindtap="{{t}}"><view class="hf-follow-row flex-row items-center justify-between"><view class="flex-col"><text class="hf-follow-title">本周随访任务</text><text class="hf-follow-sub">异常指标将自动触发重点随访</text></view><view class="hf-follow-badge"><text class="hf-follow-badge-num">{{n}}</text><text class="hf-follow-badge-sep">/</text><text class="hf-follow-badge-total">{{o}}</text></view></view><view class="hf-follow-grid"><view class="hf-follow-item"><text class="hf-follow-k">下次随访</text><text class="hf-follow-v">{{p}}</text></view><view class="hf-follow-item"><text class="hf-follow-k">上次随访</text><text class="hf-follow-v">{{q}}</text></view><view class="hf-follow-item"><text class="hf-follow-k">依从建议</text><text class="hf-follow-v">{{r}}</text></view><view class="hf-follow-item"><text class="hf-follow-k">重点指标</text><text class="hf-follow-v">{{s}}</text></view></view></view><view class="hf-section flex-row items-center justify-between"><text class="app-section-title">病例信息</text><view class="hf-link flex-row items-center" bindtap="{{x}}"><text class="hf-link-text">{{v}}</text><text class="hf-arrow">{{w}}</text></view></view><view class="hf-med app-card"><view class="hf-med-head flex-row items-start justify-between"><view class="flex-col"><text class="hf-med-title">{{y}}</text><text class="hf-med-sub">{{z}} · {{A}}</text></view><view class="hf-med-time"><text class="hf-med-time-k">入院</text><text class="hf-med-time-v">{{B}}</text></view></view><view class="hf-med-block"><text class="hf-med-k">主诉</text><text class="hf-med-v">{{C}}</text></view><view class="hf-med-block"><text class="hf-med-k">诊断</text><text class="hf-med-v">中医：{{D}}</text><text class="hf-med-v">西医：{{E}}</text></view><view class="hf-med-chips"><text wx:for="{{F}}" wx:for-item="h" wx:key="b" class="hf-chip">{{h.a}}</text></view><view wx:if="{{G}}" class="hf-med-more"><view class="hf-med-split"></view><view class="hf-med-block"><text class="hf-med-k">生命体征</text><text class="hf-med-v">{{H}}</text></view><view class="hf-med-block"><text class="hf-med-k">手术/过敏</text><text class="hf-med-v">{{I}}</text><text class="hf-med-v">{{J}}</text></view><view class="hf-med-block"><text class="hf-med-k">检查要点</text><text class="hf-med-v">{{K}}</text></view></view></view><view class="hf-footnote"><text class="hf-footnote-text">档案内容仅供本人查看；医生端与小程序数据一致，平台将严格保护隐私安全。</text></view></view>