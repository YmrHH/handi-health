<view class="app-page msg"><view class="app-card app-card--glass msg-head"><view class="flex-row items-start justify-between"><view class="flex-col"><text class="msg-title">消息中心</text><text class="msg-sub">医生建议与系统提醒会在这里统一汇总。</text></view><view class="msg-chip"><text class="msg-chip-text">{{a}} 未读</text></view></view></view><view class="app-card msg-tabs"><view class="{{['msg-tab', e]}}" bindtap="{{f}}"><text class="{{['msg-tab-text', b]}}">医生建议</text><view wx:if="{{c}}" class="msg-dot"><text class="msg-dot-text">{{d}}</text></view></view><view class="{{['msg-tab', j]}}" bindtap="{{k}}"><text class="{{['msg-tab-text', g]}}">系统提醒</text><view wx:if="{{h}}" class="msg-dot"><text class="msg-dot-text">{{i}}</text></view></view></view><view class="msg-tools"><view class="msg-tool" bindtap="{{l}}"><text class="msg-tool-text">全部已读</text></view><view class="msg-tool" bindtap="{{m}}"><text class="msg-tool-text">清空已读</text></view></view><view class="app-card msg-list"><view wx:if="{{n}}" class="msg-empty"><text class="msg-empty-text">暂无消息</text><text class="msg-empty-sub">医生建议会在医生端审核后下发；系统提醒来自任务、指标与设备状态。</text></view><view wx:for="{{o}}" wx:for-item="it" wx:key="g" class="{{['msg-item', it.h]}}" bindtap="{{it.i}}"><view class="flex-row items-center justify-between"><view class="flex-row items-center"><view class="{{['msg-icon', it.a]}}"></view><text class="msg-item-title">{{it.b}}</text></view><text class="msg-item-time">{{it.c}}</text></view><text class="msg-item-preview">{{it.d}}</text><view class="msg-item-foot flex-row items-center justify-between"><text class="msg-item-tag">{{it.e}}</text><text class="msg-item-more">{{it.f}}</text></view></view></view></view>