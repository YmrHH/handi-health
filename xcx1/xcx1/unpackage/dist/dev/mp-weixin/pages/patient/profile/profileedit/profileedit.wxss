/* =========================================================
   编辑资料：与健康档案同款玻璃风
   ========================================================= */
.pe{
  padding-bottom: 220rpx;
}
.pe-head{
  padding: 10rpx 6rpx 8rpx;
}
.pe-title{
  font-size: 40rpx;
  font-weight: 900;
  color: var(--c-text);
}
.pe-sub{
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(31,42,55,0.55);
  font-weight: 600;
}
.pe-avatar-card{
  padding: 22rpx;
  margin-top: 18rpx;
}
.pe-avatar{
  width: 86rpx;
  height: 86rpx;
  border-radius: 999rpx;
  border: 6rpx solid rgba(91,108,255,0.20);
  margin-right: 16rpx;
}
.pe-name{
  font-size: 32rpx;
  font-weight: 900;
  color: var(--c-text);
}
.pe-tip{
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(31,42,55,0.55);
  font-weight: 600;
}
.pe-arrow{
  font-size: 34rpx;
  color: rgba(31,42,55,0.35);
  font-weight: 800;
}
.pe-card{
  margin-top: 18rpx;
  padding: 18rpx 22rpx 8rpx;
}
.pe-section{
  font-size: 28rpx;
  font-weight: 900;
  color: rgba(31,42,55,0.75);
  margin-bottom: 6rpx;
}
.pe-field{
  height: 92rpx;
}
.pe-label{
  font-size: 28rpx;
  color: rgba(31,42,55,0.78);
  font-weight: 800;
}
.pe-input{
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 700;
  padding-left: 18rpx;
}
.pe-input-num{
  width: 200rpx;
}
.pe-ph{
  color: rgba(31,42,55,0.35);
  font-weight: 600;
}
.pe-unit{
  margin-left: 10rpx;
  font-size: 24rpx;
  color: rgba(31,42,55,0.45);
  font-weight: 700;
}
.pe-picker{
  min-width: 260rpx;
  justify-content: flex-end;
}
.pe-picker-text{
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 700;
}
.pe-line{
  height: 1rpx;
  background: rgba(31,42,55,0.08);
}
.pe-spacer{
  height: 190rpx;
}

/* 固定底部按钮 */
.pe-footer{
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  /* fallback bottom for devices that don't support env/constant */
  bottom: 24rpx;
  bottom: calc(constant(safe-area-inset-bottom) + 18rpx);
  bottom: calc(env(safe-area-inset-bottom) + 18rpx);
  z-index: 999;
}
.pe-save{
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  /* fallback background if global btn-primary gradient fails */
  background: linear-gradient(135deg, #5b6cff 0%, #8a7bff 100%);
}
.btn-ghost{
  margin-top: 14rpx;
  padding: 18rpx 0;
  text-align: center;
  border-radius: var(--r-pill);
  border: 1rpx solid rgba(91,108,255,0.20);
  background: rgba(255,255,255,0.72);
  color: rgba(31,42,55,0.70);
  font-size: 30rpx;
  font-weight: 700;
}
.pe-cancel{
}
.pe-save-text{
  display: block;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

/* 修改密码 */
.pe-pwd-actions{
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}
.pe-pwd-btn{
  min-width: 220rpx;
}
.pe-pwd-tip{
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(31,42,55,0.55);
  line-height: 1.5;
}
