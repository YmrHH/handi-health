/* pages/patient/spo2/spo2.css */
.sp{ padding-top: 24rpx;
}
.sp-head{ padding: 26rpx;
}
.sp-title{ font-size: 36rpx; font-weight: 800; color: var(--c-text);
}
.sp-sub{ margin-top: 8rpx; font-size: 26rpx; color: var(--c-subtext); line-height: 36rpx;
}
.sp-main{ margin-top: 18rpx; padding: 24rpx;
}
.sp-main-label{ font-size: 30rpx; font-weight: 800; color: var(--c-text);
}
.sp-main-hint{ margin-top: 8rpx; font-size: 24rpx; color: var(--c-subtext);
}
.sp-main-right{ text-align: right;
}
.sp-val{ font-size: 56rpx; font-weight: 900; color: var(--c-text);
}
.sp-unit{ margin-left: 6rpx; font-size: 24rpx; color: rgba(31,42,55,0.55);
}
.sp-chip{
  margin-top: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  display: inline-block;
  font-size: 22rpx;
  font-weight: 800;
  border: 1rpx solid rgba(91,108,255,0.14);
}
.chip-high{ background: rgba(255,99,132,0.16); color: #B42318; border-color: rgba(255,99,132,0.22);
}
.chip-mid{ background: rgba(245,158,11,0.16); color: #92400E; border-color: rgba(245,158,11,0.22);
}
.chip-low{ background: rgba(16,185,129,0.16); color: #065F46; border-color: rgba(16,185,129,0.22);
}
.sp-trend{ margin-top: 18rpx; padding: 24rpx;
}
.sp-trend-title{ font-size: 30rpx; font-weight: 800; color: var(--c-text);
}
.sp-trend-btn{ padding: 10rpx 18rpx; border-radius: 999rpx;
}
.sp-empty{ margin-top: 18rpx; padding: 18rpx 10rpx; text-align: center;
}
.sp-empty-title{ font-size: 30rpx; font-weight: 800; color: var(--c-text);
}
.sp-empty-sub{ margin-top: 10rpx; font-size: 24rpx; color: var(--c-subtext); line-height: 34rpx;
}
.sp-empty-actions{ margin-top: 16rpx; justify-content: center;
}
.sp-empty-btn{ padding: 10rpx 18rpx; border-radius: 999rpx;
}
.sp-bars{
  margin-top: 18rpx;
  height: 220rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.55);
  border: 1rpx solid rgba(91,108,255,0.12);
  display: flex;
  align-items: flex-end;
  padding: 18rpx 14rpx 12rpx;
}
.sp-bar{ flex: 1; display: flex; flex-direction: column; justify-content: flex-end; align-items: center;
}
.sp-bar-inner{
  width: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(14,165,233,0.85) 0%, rgba(91,108,255,0.45) 100%);
  box-shadow: 0 10rpx 24rpx rgba(14,165,233,0.14);
}
.sp-bar-x{ margin-top: 10rpx; font-size: 20rpx; color: rgba(31,42,55,0.50);
}
.sp-stats{ margin-top: 14rpx; display: flex; justify-content: space-between;
}
.sp-stat{ font-size: 24rpx; color: rgba(31,42,55,0.55);
}
.sp-tips{ margin-top: 18rpx; padding: 24rpx;
}
.sp-tips-title{ font-size: 30rpx; font-weight: 800; color: var(--c-text);
}
.sp-tip{ margin-top: 12rpx; font-size: 26rpx; line-height: 40rpx; color: rgba(31,42,55,0.78);
}
