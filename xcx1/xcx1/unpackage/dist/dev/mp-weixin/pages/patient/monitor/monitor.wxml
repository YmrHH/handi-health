<view class="page monitor-page"><view class="tab-bar"><view class="{{a}}" data-tab="daily" bindtap="{{b}}">日常自测</view><view class="{{c}}" data-tab="lab" bindtap="{{d}}">医院检查结果</view></view><view wx:if="{{e}}" class="tab-content"><view class="card basic-info-card"><view class="section-title-row"><view class="section-title">基础信息</view><view class="section-action" bindtap="{{f}}">编辑</view></view><view class="info-summary-row"><view class="info-item"><view class="info-label">身高</view><view class="info-value">{{g}} <text class="info-unit">cm</text></view></view><view class="info-item"><view class="info-label">基础体重</view><view class="info-value">{{h}} <text class="info-unit">kg</text></view></view><view class="info-item"><view class="info-label">BMI</view><view class="{{j}}">{{i}}</view></view></view><view class="info-updated">上次更新: {{k}}</view></view><view class="card"><view class="section-title">今日血压 / 心率</view><view class="realtime-note">实时更新，请输入最新测量的数值</view><view class="field-row"><view class="field-label">血压</view><view class="field-input"><input type="digit" placeholder="收缩压" placeholder-class="placeholder" value="{{l}}" data-field="sbp" bindinput="{{m}}"/><text class="field-unit">/</text><input type="digit" placeholder="舒张压" placeholder-class="placeholder" value="{{n}}" data-field="dbp" bindinput="{{o}}"/><text class="field-unit">mmHg</text></view></view><view class="field-row"><view class="field-label">心率</view><view class="field-input"><input type="digit" placeholder="请输入心率" placeholder-class="placeholder" value="{{p}}" data-field="hr" bindinput="{{q}}"/><text class="field-unit">次/分</text></view></view><view wx:if="{{r}}" class="last-updated">上次测量: {{s}}</view></view><view class="card"><view class="section-title">今日症状与生活情况</view><view class="field-row"><view class="field-label">睡眠情况</view><picker mode="selector" range="{{v}}" value="{{w}}" bindchange="{{x}}"><view class="picker-display">{{t}}</view></picker></view><view class="field-row"><view class="field-label">食欲情况</view><picker mode="selector" range="{{z}}" value="{{A}}" bindchange="{{B}}"><view class="picker-display">{{y}}</view></picker></view><view class="field-row"><view class="field-label">大便情况</view><picker mode="selector" range="{{D}}" value="{{E}}" bindchange="{{F}}"><view class="picker-display">{{C}}</view></picker></view><view class="field-row"><view class="field-label">今日血氧 (SpO₂) <text class="sync-badge" bindtap="{{G}}">同步血氧</text></view><view class="field-input"><input type="digit" placeholder="请输入血氧或同步" placeholder-class="placeholder" value="{{H}}" data-field="spo2" bindinput="{{I}}"/><text class="field-unit">%</text></view></view><view wx:if="{{J}}" class="last-updated">上次更新: {{K}}</view><view class="field-row"><view class="field-label">其他症状</view><block wx:if="{{r0}}"><textarea class="textarea" placeholder="如胸闷、气短、下肢水肿等" placeholder-class="placeholder" value="{{L}}" data-field="symptomNote" bindinput="{{M}}"></textarea></block></view></view><view class="card"><button class="btn-primary" bindtap="{{N}}">保存今日记录</button></view></view><view wx:elif="{{O}}" class="tab-content"><view wx:for="{{P}}" wx:for-item="item" wx:key="f" class="card"><view class="lab-header"><view class="lab-date">{{item.a}}</view><view class="lab-hospital">{{item.b}}</view></view><view class="lab-items"><view wx:for="{{item.c}}" wx:for-item="labItem" wx:key="f" class="lab-item"><view class="lab-name">{{labItem.a}}</view><view class="lab-right"><text class="lab-value">{{labItem.b}}</text><text class="lab-unit">{{labItem.c}}</text><text class="{{labItem.e}}">{{labItem.d}}</text></view></view></view><view wx:if="{{item.d}}" class="lab-note">医生提示：{{item.e}}</view></view><view wx:if="{{Q}}" class="empty-lab">暂无医院化验结果记录，可在门诊化验后由医护人员录入。</view></view></view><view wx:if="{{R}}" class="popup-container"><view class="popup-mask" bindtap="{{S}}"></view><view class="popup-content"><view class="popup-title">编辑基础信息</view><view class="popup-form"><view class="popup-field"><view class="popup-label">身高 (cm)</view><input type="digit" class="popup-input" placeholder="请输入身高" value="{{T}}" bindinput="{{U}}"/></view><view class="popup-field"><view class="popup-label">基础体重 (kg)</view><input type="digit" class="popup-input" placeholder="请输入基础体重" value="{{V}}" bindinput="{{W}}"/></view></view><view class="popup-actions"><button class="popup-btn cancel" bindtap="{{X}}">取消</button><button class="popup-btn confirm" bindtap="{{Y}}">确认</button></view></view></view>