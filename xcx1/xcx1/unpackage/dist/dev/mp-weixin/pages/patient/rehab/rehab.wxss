/* pages/patient/rehab/rehab.wxss */
page {
    background-color: #f5f7fb;
}
.page {
    padding: 24rpx;
}
/* 顶部概览 */
.rehab-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.rehab-title {
    font-size: 32rpx;
    font-weight: 600;
}
.rehab-sub {
    margin-top: 6rpx;
    font-size: 24rpx;
    color: #6b7280;
}
.rehab-score {
    padding: 14rpx 10rpx;
    border-radius: 12rpx;
    background-color: #e8f1ff;
    text-align: center;
}
.rehab-score-num {
    font-size: 32rpx;
    font-weight: 700;
    color: #1d4ed8;
}
.rehab-score-label {
    font-size: 22rpx;
    color: #1d4ed8;
}
/* 筛选 tabs */
.filter-tabs {
    display: flex;
    margin-top: 16rpx;
}
.filter-tab {
    font-size: 24rpx;
    padding: 6rpx 16rpx;
    border-radius: 999rpx;
    background-color: #eff1f5;
    color: #4b5563;
    margin-right: 12rpx;
}
.filter-tab.active {
    background-color: #2972f6;
    color: #ffffff;
}
/* 任务卡片 */
.task-card {
    margin-top: 16rpx;
    padding: 16rpx 14rpx;
    border-radius: 16rpx;
    background-color: #ffffff;
    box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.05);
}
.task-main {
    display: flex;
    justify-content: space-between;
}
.task-left {
    display: flex;
}
.task-icon {
    width: 64rpx;
    height: 64rpx;
    border-radius: 999rpx;
    background-color: #e8f1ff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 16rpx;
    font-size: 34rpx;
}
.task-title {
    font-size: 28rpx;
    font-weight: 600;
}
.task-meta {
    margin-top: 4rpx;
    font-size: 22rpx;
    color: #6b7280;
}
.task-desc {
    margin-top: 4rpx;
    font-size: 24rpx;
    color: #374151;
}
.task-status {
    align-self: flex-start;
}
.status-tag {
    font-size: 22rpx;
    padding: 4rpx 12rpx;
    border-radius: 999rpx;
}
.status-todo {
    background-color: #fef3c7;
    color: #b45309;
}
.status-done {
    background-color: #dcfce7;
    color: #166534;
}
/* 底部区：难度+按钮 */
.task-footer {
    margin-top: 12rpx;
    padding-top: 10rpx;
    border-top: 1rpx solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.difficulty-label {
    font-size: 24rpx;
    color: #6b7280;
}
.difficulty-buttons {
    flex: 1;
    margin-left: 6rpx;
}
.diff-btn {
    margin-right: 8rpx;
    font-size: 22rpx;
    padding: 0 16rpx;
    border-radius: 999rpx;
    border: 2rpx solid #d1d5db;
    color: #4b5563;
    background-color: #ffffff;
}
.diff-btn.active {
    border-color: #2972f6;
    color: #2972f6;
    background-color: #e8f1ff;
}
.task-btn {
    min-width: 150rpx;
    font-size: 24rpx;
    border-radius: 999rpx;
    background-color: #2972f6;
    color: #ffffff;
}
.task-btn-done {
    background-color: #6b7280;
}
.empty-tip {
    font-size: 24rpx;
    color: #6b7280;
    text-align: center;
}
/* 复用的蓝色提示块，可也放 app.wxss */
.tip-blue {
    background-color: #e8f1ff;
    border-radius: 12rpx;
    padding: 16rpx 18rpx;
    font-size: 24rpx;
    color: #1d4ed8;
}
.overdue-banner {
    margin-top: 16rpx;
    padding: 14rpx 18rpx;
    border-radius: 12rpx;
    background: rgba(245, 158, 11, 0.12);
    color: #b45309;
    font-size: 24rpx;
}
.task-deadline {
    margin-top: 6rpx;
    font-size: 22rpx;
    color: #6b7280;
}
.task-deadline.overdue {
    color: #b91c1c;
}
.status-overdue {
    background-color: #fee2e2;
    color: #b91c1c;
}
