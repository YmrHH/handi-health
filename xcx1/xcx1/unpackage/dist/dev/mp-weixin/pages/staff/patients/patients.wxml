<view class="page"><view class="section patient-section"><view class="section-title">风险分层患者</view><block wx:for="{{a}}" wx:for-item="item" wx:key="n"><view class="patient-card"><view class="patient-card-header"><view class="patient-name-row"><text class="patient-name">{{item.a}}</text><text class="patient-age">（{{item.b}}岁）</text></view><view class="patient-risk-wrap"><text class="patient-risk-label">风险：</text><text wx:if="{{item.c}}" class="tag tag-risk-high">{{item.d}}风险</text><text wx:elif="{{item.e}}" class="tag tag-risk-mid">{{item.f}}风险</text><text wx:elif="{{item.g}}" class="tag tag-risk-low">{{item.h}}风险</text><text wx:else class="tag">{{item.i}}风险</text></view></view><view class="patient-info-row"><text class="patient-info-label">病种：</text><text class="patient-info-value">{{item.j}}</text></view><view class="patient-info-row"><text class="patient-info-label">体质：</text><text class="patient-info-value">{{item.k}} ｜ 证型：{{item.l}}</text></view></view><view class="patient-actions"><button class="mini-btn" catchtap="{{item.m}}">查看数据</button></view></block></view></view>