<view class="app-page staff-page"><view class="app-card app-card--glass staff-card"><view class="staff-header"><view><view class="staff-title">在管患者</view><view class="staff-sub">查看患者健康指标，对标患者端。</view></view></view><view class="search-bar"><input class="search-input" placeholder="搜索患者姓名/ID" confirm-type="search" bindconfirm="{{a}}" value="{{b}}" bindinput="{{c}}"/><view class="search-btn" bindtap="{{d}}">搜索</view></view></view><view class="app-card staff-card"><view class="section-title">患者列表</view><view wx:if="{{e}}" class="empty">加载中...</view><view wx:elif="{{f}}" class="empty">暂无在管患者</view><view wx:else><view wx:for="{{g}}" wx:for-item="p" wx:key="p" class="patient-card"><view class="row"><view class="name">{{p.a}} <text wx:if="{{p.b}}" class="sub"> · {{p.c}}岁</text></view><view class="{{['risk', p.e]}}">{{p.d}}</view></view><view class="meta"><text class="meta-item">ID：{{p.f}}</text><text class="meta-item">主要疾病：{{p.g}}</text></view><view class="btns"><view class="btn ghost" bindtap="{{p.h}}" data-id="{{p.i}}" data-name="{{p.j}}">查看数据</view><view class="btn primary" bindtap="{{p.m}}" data-id="{{p.n}}" data-name="{{p.o}}"> 患者消息 <text wx:if="{{p.k}}" class="badge">{{p.l}}</text></view></view></view></view></view><staff-tabbar wx:if="{{h}}" u-i="cf9e0a78-0" bind:__l="__l" u-p="{{h}}"></staff-tabbar></view>