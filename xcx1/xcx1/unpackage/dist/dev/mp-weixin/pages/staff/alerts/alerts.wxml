<view class="page alerts-page"><view class="section"><view class="section-title">待随访</view><block wx:for="{{a}}" wx:for-item="item" wx:key="h"><view class="card"><view class="row-top"><view><view class="name">{{item.a}}</view><view class="sub">{{item.b}}</view></view><view class="{{item.d}}">{{item.c}}</view></view><view class="row-bottom"><view class="time">计划时间：{{item.e}}</view><button class="btn-primary" size="mini" data-id="{{item.f}}" bindtap="{{item.g}}">开始随访</button></view></view></block></view><view class="section"><view class="section-title">已超期</view><block wx:for="{{b}}" wx:for-item="item" wx:key="g"><view class="card"><view class="row-top"><view><view class="name">{{item.a}}</view><view class="sub">{{item.b}}</view></view><view class="status-overdue">超期 {{item.c}} 天</view></view><view class="row-bottom"><view class="time">原计划：{{item.d}}</view><button class="btn-secondary" size="mini" data-id="{{item.e}}" bindtap="{{item.f}}">重新安排</button></view></view></block></view><view class="section"><view class="section-title">已完成</view><block wx:for="{{c}}" wx:for-item="item" wx:key="f"><view class="card"><view class="row-top"><view><view class="name">{{item.a}}</view><view class="sub">完成时间：{{item.b}}</view></view><view class="status-done">已完成</view></view><view class="row-bottom"><view class="time">{{item.c}}</view><button class="btn-outline" size="mini" data-id="{{item.d}}" bindtap="{{item.e}}">查看 / 修改</button></view></view></block></view></view>